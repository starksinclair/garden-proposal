# Upstash Redis (Vercel Marketplace > Upstash, or upstash.com — free tier)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (resend.com — verify your domain first so you can email HER)
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL="The Garden <hello@yourdomain.com>"

# Optional: BCC yourself so you know the exact moment she says yes
NOTIFY_EMAIL=you@example.com
